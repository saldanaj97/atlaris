# Cloud agent development runtime.
# Copy these names into the cloud agent environment; keep real secrets in the
# provider's secret store, not in git.

# Environment variables
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

LOCAL_PRODUCT_TESTING=true
DEV_AUTH_USER_ID=00000000-0000-4000-8000-000000000001
DEV_AUTH_USER_EMAIL=local-product-test@localhost.local
DEV_AUTH_USER_NAME=Local Product Test

STRIPE_LOCAL_MODE=false

AI_PROVIDER=mock
AI_USE_MOCK=true
MOCK_GENERATION_DELAY_MS=0
MOCK_GENERATION_FAILURE_RATE=0
LESSON_GENERATION_ENABLED=true

ENABLE_SENTRY=false
NEXT_PUBLIC_ENABLE_SENTRY=false
LOG_LEVEL=debug

REGENERATION_QUEUE_ENABLED=true
REGENERATION_INLINE_PROCESSING=true
REGENERATION_MAX_JOBS_PER_DRAIN=1

MODULE_LESSON_WORKFLOW_ENABLED=false
PLAN_GENERATION_WORKFLOW_ENABLED=false
PLAN_REGENERATION_WORKFLOW_ENABLED=false

# Secrets
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SIGNING_SECRET=whsec_clerk_local_placeholder

STRIPE_SECRET_KEY=sk_test_local_placeholder
STRIPE_WEBHOOK_SECRET=whsec_local_placeholder

# Optional secrets; set only when enabling these paths.
OPENROUTER_API_KEY=
REGENERATION_WORKER_TOKEN=
MAINTENANCE_WORKER_TOKEN=
CLERK_BILLING_RECONCILIATION_ENABLED=false
WORKER_HEALTH_TOKEN=
WORKFLOW_CALLBACK_TOKEN=
