NODE_ENV=
MAINTENANCE_MODE=
ENABLE_SENTRY=
LOCAL_PRODUCT_TESTING=

# Local billing: canonical price ids + in-process Stripe mock (development/test only; refused in production)
STRIPE_LOCAL_MODE=

# Local Testing Vars
DEV_AUTH_USER_ID=
DEV_AUTH_USER_EMAIL=
DEV_AUTH_USER_NAME=

# Local Docker Database
DATABASE_URL=
DATABASE_URL_NON_POOLING=
DATABASE_URL_UNPOOLED=

# Core AI Routing
AI_PROVIDER=
AI_USE_MOCK=
AI_MAX_OUTPUT_TOKENS=
AI_DEFAULT_MODEL=
AI_PRIMARY=
AI_FALLBACK=
MOCK_GENERATION_DELAY_MS=
MOCK_GENERATION_FAILURE_RATE=

# OAuth Encryption key
OAUTH_ENCRYPTION_KEY=

# Neon Auth
# Branch auth URL from Neon Console -> Branch -> Auth -> Configuration
NEON_AUTH_BASE_URL=
NEON_AUTH_JWKS_URL=

# Must be at least 32 chars. Generate with: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=

# Turbo Remote Caching
TURBO_TOKEN=
TURBO_TEAM=

# Stripe API Keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Webhook
STRIPE_WEBHOOK_SECRET=

# Stripe Product/Price IDs (create these in Dashboard first)
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=

# OpenRouter (only if enabling overflow/paid)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

# Plan Generation Polling
# Use shorter times for quick development and testing
NEXT_PLAN_GENERATION_POLL_INTERVAL_MS=
NEXT_PLAN_GENERATION_MAX_POLLS=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
