NODE_ENV=
MAINTENANCE_MODE=
ENABLE_SENTRY=
LOCAL_PRODUCT_TESTING=

# Shared bearer token for queued regeneration worker drains
REGENERATION_WORKER_TOKEN=

# Shared bearer token for the manual retention cleanup route
MAINTENANCE_WORKER_TOKEN=

# Local billing: canonical price ids + in-process Stripe mock (development/test only; refused in production)
STRIPE_LOCAL_MODE=

# Local Testing Vars
DEV_AUTH_USER_ID=
DEV_AUTH_USER_EMAIL=
DEV_AUTH_USER_NAME=

# Local Dev Supabase Setup
# Local defaults come from `supabase status` after `pnpm db:dev:start`.
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Core AI Routing
AI_PROVIDER=
AI_USE_MOCK=
AI_MAX_OUTPUT_TOKENS=
AI_DEFAULT_MODEL=
AI_PRIMARY=
AI_FALLBACK=
MOCK_GENERATION_DELAY_MS=
MOCK_GENERATION_FAILURE_RATE=

# OAuth Encryption key
OAUTH_ENCRYPTION_KEY=

# Turbo Remote Caching
TURBO_TOKEN=
TURBO_TEAM=

# Stripe API Keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Webhook
STRIPE_WEBHOOK_SECRET=

# Stripe Product/Price IDs (create these in Dashboard first)
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=

# OpenRouter (only if enabling overflow/paid)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

# Plan Generation Polling
# Use shorter times for quick development and testing
NEXT_PLAN_GENERATION_POLL_INTERVAL_MS=
NEXT_PLAN_GENERATION_MAX_POLLS=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
