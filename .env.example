NODE_ENV=
MAINTENANCE_MODE=
ENABLE_SENTRY=
# Sentry: forward user PII to Sentry server-side (default false). Mirrors the
# client opt-in NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII.
SENTRY_SEND_DEFAULT_PII=
LOCAL_PRODUCT_TESTING=
# Canonical public app origin (https required in production). Used for email
# deeplinks and signed unsubscribe URLs when email delivery is enabled.
APP_URL=

# --- Workflow SDK (see docs/development/environment.md#workflow-sdk) ---
# WORKFLOW_SOURCEMAP: optional; read by Workflow SDK at build/runtime, not parsed in app code.
WORKFLOW_SOURCEMAP=

# Product flags (default off). Accepted: true|false|1|0 — no secret values to generate.

# Module lesson POST .../lesson-content/generate → durable workflow (202 while in flight).
# Also requires LESSON_GENERATION_ENABLED=true.
MODULE_LESSON_WORKFLOW_ENABLED=false

# Plan create/retry SSE: reserves attempt in-process, runs provider/finalization in workflow.
PLAN_GENERATION_WORKFLOW_ENABLED=false

# Queued plan regeneration → durable workflow on enqueue and worker drain.
# Also requires REGENERATION_QUEUE_ENABLED=true (and inline processing or worker cron).
PLAN_REGENERATION_WORKFLOW_ENABLED=false

# Shared bearer token for non-Vercel workflow callback routes (/.well-known/workflow/v1/*).
# Required on self-hosted production. Not used on Vercel (queue consumer security).
# Generate any strong random string (e.g. openssl rand -hex 32). Local dev with pnpm dev:workflow
# does not need this unless you harden local callbacks beyond the default x-vqs header check.
WORKFLOW_CALLBACK_TOKEN=

# --- Regeneration queue (required for regeneration workflow; separate from Workflow SDK) ---
# Master switch for POST .../regenerate enqueue and worker drain.
REGENERATION_QUEUE_ENABLED=true
# Local/test: process jobs inline from enqueue. Production: use false + scheduled worker.
REGENERATION_INLINE_PROCESSING=false
# Max jobs per POST /api/internal/jobs/regeneration/process invocation.
REGENERATION_MAX_JOBS_PER_DRAIN=1
# Bearer token for regeneration worker route. Required in production when queue is enabled.
# Generate any strong random string (e.g. openssl rand -hex 32). Not needed for typical local dev with inline processing.
REGENERATION_WORKER_TOKEN=

# Module lesson generation master switch (development defaults to on if unset).
LESSON_GENERATION_ENABLED=

# Shared bearer token for the manual retention cleanup route, only needed when enabled
MAINTENANCE_WORKER_TOKEN=

# Separate Vercel Cron bearer secret for GET /api/cron/notifications/email.
# Never reuse MAINTENANCE_WORKER_TOKEN; generate with openssl rand -hex 32.
CRON_SECRET=

# Bearer token for GET /api/health/worker operator metrics. Required in production.
WORKER_HEALTH_TOKEN=

# Master switch for the manual retention cleanup HTTP route; Supabase Cron is separate
RETENTION_CLEANUP_ENABLED=

# Master switch for the manual plan cleanup HTTP route (stuck plans + orphaned attempts)
PLAN_CLEANUP_ENABLED=

# Master switch for manual Clerk Billing reconciliation
CLERK_BILLING_RECONCILIATION_ENABLED=

# --- Opted-in email notifications ---
# Send enablement is controlled by the Vercel Flag `email-notification-delivery`
# (fail-closed / default disabled). Before enabling the flag, also set APP_URL
# (canonical https origin) — the worker builds unsubscribe and plan/analytics
# links from appEnv.url on the first page. Keep RESEND_* and the unsubscribe
# secret configured so signed unsubscribe links remain valid for the token
# lifetime even while outbound delivery is disabled.
RESEND_API_KEY=
# Canonical From header, e.g. Atlaris <notifications@mail.atlaris.app>
RESEND_FROM=
# Optional Reply-To
RESEND_REPLY_TO=
# HMAC secret for signed unsubscribe links. Use unpadded base64url encoding of at
# least 32 random bytes (for example: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))").
# Keep configured for at least the maximum token lifetime after the last email is sent;
# do not remove as a kill switch.
EMAIL_UNSUBSCRIBE_TOKEN_SECRET=

# Local Testing Vars
DEV_AUTH_USER_ID=
DEV_AUTH_USER_EMAIL=
DEV_AUTH_USER_NAME=

# Local Dev Supabase Setup
# Local defaults come from `supabase status` after `pnpm db:dev:start`.
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Core AI Routing
AI_PROVIDER=
AI_USE_MOCK=
AI_MAX_OUTPUT_TOKENS=
AI_DEFAULT_MODEL=
AI_PRIMARY=
AI_FALLBACK=
MOCK_GENERATION_DELAY_MS=
MOCK_GENERATION_FAILURE_RATE=

# OAuth Encryption key
OAUTH_ENCRYPTION_KEY=

# Turbo Remote Caching
TURBO_TOKEN=
TURBO_TEAM=

# OpenRouter (only if enabling overflow/paid)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

# Plan Generation Polling
# Use shorter times for quick development and testing
NEXT_PLAN_GENERATION_POLL_INTERVAL_MS=
NEXT_PLAN_GENERATION_MAX_POLLS=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
