# Local development runtime. Keep this as `development` so local auth bypasses and dev-only mocks are allowed.
NODE_ENV=development

# Local app origin used for redirects and absolute URLs.
APP_URL=http://localhost:3000

# Local maintenance page toggle. Keep false during normal development.
MAINTENANCE_MODE=false

# Disable server-side Sentry in local development.
ENABLE_SENTRY=false

# Disable browser-side Sentry in local development.
NEXT_PUBLIC_ENABLE_SENTRY=false

# Enable the seeded local auth bypass for fast development.
LOCAL_PRODUCT_TESTING=true

# Seeded local auth user id created by `pnpm db:dev:bootstrap`.
DEV_AUTH_USER_ID=local-product-testing-user

# Seeded local auth email shown in local product testing.
DEV_AUTH_USER_EMAIL=dev@example.com

# Seeded local auth display name shown in local product testing.
DEV_AUTH_USER_NAME=Dev User

# Local Supabase Postgres URL from `pnpm db:dev:start`.
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Direct local Postgres URL used by migrations and non-pooling server clients.
POSTGRES_URL_NON_POOLING=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Local Supabase API URL from `pnpm exec supabase status`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Local Supabase publishable or anon key from `pnpm exec supabase status`.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Clerk publishable key. Not used when LOCAL_PRODUCT_TESTING is active, but keep a test key available for auth UI work.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Clerk secret key. Not used when LOCAL_PRODUCT_TESTING is active, but keep a test key available for auth route work.
CLERK_SECRET_KEY=sk_test_replace_me

# Use in-process Stripe mocks for local development.
STRIPE_LOCAL_MODE=true

# Local Stripe placeholder; local mode provides the in-process mock.
STRIPE_SECRET_KEY=sk_test_local_placeholder

# Local webhook secret placeholder for webhook route testing.
STRIPE_WEBHOOK_SECRET=whsec_local_placeholder

# Local catalog starter monthly price id.
STRIPE_STARTER_MONTHLY_PRICE_ID=price_local_starter_monthly

# Local catalog starter yearly price id.
STRIPE_STARTER_YEARLY_PRICE_ID=price_local_starter_yearly

# Local catalog pro monthly price id.
STRIPE_PRO_MONTHLY_PRICE_ID=price_local_pro_monthly

# Local catalog pro yearly price id.
STRIPE_PRO_YEARLY_PRICE_ID=price_local_pro_yearly

# Use mock AI locally for fast iteration without provider spend.
AI_PROVIDER=mock

# Force mock AI when the provider factory checks the legacy toggle.
AI_USE_MOCK=true

# Optional local mock generation delay in milliseconds.
MOCK_GENERATION_DELAY_MS=500

# Optional local mock failure rate; keep 0 for deterministic development.
MOCK_GENERATION_FAILURE_RATE=0

# Enable module lesson generation locally so generation features can be verified.
LESSON_GENERATION_ENABLED=true

# Disable queued regeneration until the worker scheduler is ready.
REGENERATION_QUEUE_ENABLED=false

# Keep inline regeneration off while the queue feature is being hardened.
REGENERATION_INLINE_PROCESSING=false

# Future regeneration worker drain batch size for local worker testing.
REGENERATION_MAX_JOBS_PER_DRAIN=1

# Future shared bearer token for local regeneration worker route testing.
REGENERATION_WORKER_TOKEN=local-regeneration-worker-token

# Disable the manual app retention route locally; Supabase Cron owns scheduled retention.
RETENTION_CLEANUP_ENABLED=false

# Future shared bearer token for local manual retention route testing.
MAINTENANCE_WORKER_TOKEN=local-maintenance-worker-token

# Local log verbosity.
LOG_LEVEL=debug
