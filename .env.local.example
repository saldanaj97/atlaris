# Local development environment template (values intentionally blank where needed).

# --- Local Supabase stack ---
# Start it with `pnpm db:dev:start`, then copy the current publishable key from
# `pnpm exec supabase status`.
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Local product testing ---
# This deterministic seeded identity is created by `pnpm db:dev:reset`.
LOCAL_PRODUCT_TESTING=true
DEV_AUTH_USER_ID=00000000-0000-4000-8000-000000000001

# --- Observability ---
# Disable Sentry locally to avoid sending development telemetry.
ENABLE_SENTRY=false
NEXT_PUBLIC_ENABLE_SENTRY=false

# --- Background plan regeneration ---
# Disable background work locally. Both settings otherwise default to true in development.
REGENERATION_QUEUE_ENABLED=false
REGENERATION_INLINE_PROCESSING=false

# --- Focused Clerk testing only ---
# Local product testing bypasses Clerk UI. Add NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
# and CLERK_SECRET_KEY only when testing real Clerk flows; add
# CLERK_WEBHOOK_SIGNING_SECRET only when testing Clerk Billing webhooks.

# --- AI and Workflow SDK ---
# Development already defaults to the mock AI provider. Leave Workflow SDK flags
# and callback settings unset locally; use a Vercel Preview deployment to test workflows.
