# Production runtime.
NODE_ENV=production

# Production app origin used for redirects and absolute URLs. Must be HTTPS.
APP_URL=https://atlaris.app

# Production maintenance page toggle.
MAINTENANCE_MODE=false

# Disable server-side Sentry until production observability is intentionally configured.
ENABLE_SENTRY=false

# Disable browser-side Sentry until production observability is intentionally configured.
NEXT_PUBLIC_ENABLE_SENTRY=false

# Production Supabase Postgres URL.
POSTGRES_URL=postgresql://...

# Production direct/non-pooling Postgres URL for migrations and server DB clients.
POSTGRES_URL_NON_POOLING=postgresql://...

# Production Supabase API URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co

# Production Supabase publishable key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Production Clerk publishable key.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace_me

# Production Clerk secret key.
CLERK_SECRET_KEY=sk_live_replace_me

# Production Clerk/Svix webhook signing secret.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_clerk_replace_me

# Use mock AI for the minimal no-provider-spend launch. Switch to `router` when using OpenRouter.
AI_PROVIDER=mock

# Keep false in production; production mock/router choice is controlled by AI_PROVIDER.
AI_USE_MOCK=false

# Disable module lesson generation until production AI/provider cost behavior is intentionally enabled.
LESSON_GENERATION_ENABLED=false

# --- Workflow SDK (see docs/architecture/workflow-sdk.md) ---
# Optional workflow debugging source maps (inline|linked|external|both|false). Leave empty in hosted envs.
WORKFLOW_SOURCEMAP=

# Product flags: true|false|1|0. Keep false until workflow paths are validated in this environment.

# Module lessons via durable workflow (HTTP 202). Requires LESSON_GENERATION_ENABLED=true.
MODULE_LESSON_WORKFLOW_ENABLED=false

# Plan create/retry: durable provider/finalization behind existing SSE.
PLAN_GENERATION_WORKFLOW_ENABLED=false

# Plan regeneration via workflow. Requires REGENERATION_QUEUE_ENABLED=true and worker drains
# (REGENERATION_WORKER_TOKEN on POST /api/internal/jobs/regeneration/process).
PLAN_REGENERATION_WORKFLOW_ENABLED=false

# Disable queued regeneration until the worker scheduler is ready.
REGENERATION_QUEUE_ENABLED=false

# Keep inline regeneration disabled in production.
REGENERATION_INLINE_PROCESSING=false

# Future regeneration worker drain batch size for production once enabled.
REGENERATION_MAX_JOBS_PER_DRAIN=1

# Future shared bearer token for the production regeneration worker route once enabled.
REGENERATION_WORKER_TOKEN=replace-with-strong-production-secret

# Disable the manual app retention route in production; Supabase Cron owns scheduled retention.
RETENTION_CLEANUP_ENABLED=false

# Enable after the GitHub Actions plan cleanup scheduler is configured.
PLAN_CLEANUP_ENABLED=false

# Enable only while running manual Clerk Billing drift repair.
CLERK_BILLING_RECONCILIATION_ENABLED=false

# Shared bearer token for production maintenance routes and the plan cleanup scheduler.
MAINTENANCE_WORKER_TOKEN=replace-with-strong-production-secret
# Separate bearer token supplied by Vercel Cron to GET /api/cron/notifications/email.
CRON_SECRET=replace-with-strong-production-secret
WORKER_HEALTH_TOKEN=replace-with-strong-production-secret

# Production log verbosity.
LOG_LEVEL=info
