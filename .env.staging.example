# Staging runtime. Use `production` so staging exercises production-only code paths.
NODE_ENV=production

# Staging app origin used for redirects and absolute URLs.
APP_URL=https://staging.atlaris.app

# Staging maintenance page toggle.
MAINTENANCE_MODE=false

# Disable server-side Sentry unless staging observability is intentionally configured.
ENABLE_SENTRY=false

# Disable browser-side Sentry unless staging observability is intentionally configured.
NEXT_PUBLIC_ENABLE_SENTRY=false

# Staging Supabase Postgres URL. Use the atlaris-dev remote staging database URL.
POSTGRES_URL=postgresql://...

# Staging direct/non-pooling Postgres URL. Use the atlaris-dev remote staging direct connection URL.
POSTGRES_URL_NON_POOLING=postgresql://...

# Staging Supabase API URL for the atlaris-dev project.
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co

# Staging Supabase publishable key for the atlaris-dev project.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Staging Clerk publishable key. Do not use local auth bypasses in staging.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Staging Clerk secret key. Do not use local auth bypasses in staging.
CLERK_SECRET_KEY=sk_test_replace_me

# Staging Clerk/Svix webhook signing secret.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_clerk_replace_me

# Use mock AI in staging by default to avoid provider spend while manually testing flows.
AI_PROVIDER=mock

# Force mock AI when the provider factory checks the legacy toggle.
AI_USE_MOCK=true

# Optional staging mock generation delay in milliseconds.
MOCK_GENERATION_DELAY_MS=500

# Optional staging mock failure rate; keep 0 for deterministic manual testing.
MOCK_GENERATION_FAILURE_RATE=0

# Enable module lesson generation in staging so the feature can be manually tested.
LESSON_GENERATION_ENABLED=true

# --- Workflow SDK (see docs/architecture/workflow-sdk.md) ---
# Optional workflow debugging source maps (inline|linked|external|both|false). Leave empty in hosted envs.
WORKFLOW_SOURCEMAP=

# Product flags: true|false|1|0. Keep false until workflow paths are validated in this environment.

# Module lessons via durable workflow (HTTP 202). Requires LESSON_GENERATION_ENABLED=true.
MODULE_LESSON_WORKFLOW_ENABLED=false

# Plan create/retry: durable provider/finalization behind existing SSE.
PLAN_GENERATION_WORKFLOW_ENABLED=false

# Plan regeneration via workflow. Requires REGENERATION_QUEUE_ENABLED=true and worker drains
# (REGENERATION_WORKER_TOKEN on POST /api/internal/jobs/regeneration/process).
PLAN_REGENERATION_WORKFLOW_ENABLED=false

# Disable queued regeneration until the worker scheduler is ready.
REGENERATION_QUEUE_ENABLED=false

# Keep inline regeneration disabled in staging.
REGENERATION_INLINE_PROCESSING=false

# Future regeneration worker drain batch size for staging worker testing.
REGENERATION_MAX_JOBS_PER_DRAIN=1

# Future shared bearer token for the staging regeneration worker route.
REGENERATION_WORKER_TOKEN=replace-with-strong-staging-secret

# Disable the manual app retention route in staging; Supabase Cron owns scheduled retention.
RETENTION_CLEANUP_ENABLED=false

# Disable manual Clerk Billing reconciliation unless running drift repair.
CLERK_BILLING_RECONCILIATION_ENABLED=false

# Future shared bearer token for staging manual retention route access.
MAINTENANCE_WORKER_TOKEN=replace-with-strong-staging-secret
# Separate bearer token supplied by Vercel Cron to GET /api/cron/notifications/email.
CRON_SECRET=replace-with-strong-staging-secret


# Opted-in email notifications (Vercel Flag email-notification-delivery; fail-closed).
# APP_URL above must be the canonical https origin before enabling the flag — the
# worker builds unsubscribe and deeplink URLs from it on the first delivery page.
RESEND_API_KEY=
RESEND_FROM=
# RESEND_REPLY_TO=
EMAIL_UNSUBSCRIBE_TOKEN_SECRET=

# Staging log verbosity.
LOG_LEVEL=info
