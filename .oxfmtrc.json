{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "sortTailwindcss": {
    "stylesheet": "./src/app/globals.css"
  },
  "singleQuote": true,
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules",
    ".agents",
    ".daily-recap",
    ".next",
    ".test-dist",
    "coverage",
    "out",
    "build",
    "tests/results",
    "screenshots",
    "*.tsbuildinfo",
    "next-env.d.ts",
    ".env*"
  ]
}
