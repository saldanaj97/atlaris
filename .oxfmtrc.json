{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "sortTailwindcss": {
    "stylesheet": "./src/app/globals.css"
  },
  "printWidth": 80,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "sortImports": {
    "groups": [
      [
        "type-builtin",
        "type-external",
        "type-subpath",
        "type-internal",
        "type-parent",
        "type-sibling",
        "type-index"
      ],
      {
        "newlinesBetween": true
      },
      [
        "builtin",
        "external",
        "subpath",
        "internal",
        "parent",
        "sibling",
        "index"
      ],
      {
        "newlinesBetween": true
      },
      ["side_effect", "side_effect_style", "style"],
      "unknown"
    ],
    "internalPattern": ["@/"],
    "newlinesBetween": false,
    "partitionByComment": true
  },
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules",
    ".agents",
    ".daily-recap",
    ".next",
    ".test-dist",
    "coverage",
    "out",
    "build",
    "tests/results",
    "screenshots",
    "*.tsbuildinfo",
    "next-env.d.ts",
    ".env*"
  ]
}
