{
  "name": "atlaris",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build --turbopack",
    "dev": "next dev --turbopack",
    "dev:full": "pnpm db:dev:start && pnpm dev",
    "start": "next start",
    "check:full": "concurrently --kill-others-on-fail --names lint,type,format --prefix-colors blue,magenta,cyan \"pnpm check:lint\" \"pnpm check:type\"",
    "check:format": "prettier . --write --ignore-unknown",
    "check:lint": "oxlint src tests scripts --max-warnings=0",
    "check:lint:ci": "oxlint src tests scripts --format=github --max-warnings=0",
    "check:lint:changed": "./scripts/lint-changed.sh",
    "check:lint:fix": "oxlint src tests scripts --fix --max-warnings=0",
    "check:dead-columns": "tsx scripts/audit-drizzle-columns.ts",
    "check:type": "tsgo --noEmit --checkers 4",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:dev:start": "brew services start postgresql@17 && \"$(brew --prefix postgresql@17)/bin/pg_isready\" -h localhost -p 54331 -d postgres",
    "db:dev:stop": "brew services stop postgresql@17",
    "db:dev:bootstrap": "tsx scripts/bootstrap-local-db.ts",
    "db:dev:reset": "pnpm db:dev:start && PGPASSWORD=postgres \"$(brew --prefix postgresql@17)/bin/dropdb\" --if-exists -h localhost -p 54331 -U postgres atlaris_dev && PGPASSWORD=postgres \"$(brew --prefix postgresql@17)/bin/createdb\" -h localhost -p 54331 -U postgres -O postgres atlaris_dev",
    "test": "pnpm test:changed",
    "test:changed": "tsx scripts/tests/run.ts changed",
    "test:unit": "tsx scripts/tests/run.ts unit",
    "test:unit:changed": "tsx scripts/tests/run.ts unit --changed",
    "test:integration:changed": "tsx scripts/tests/run.ts integration --changed",
    "test:integration": "tsx scripts/tests/run.ts integration",
    "test:security": "tsx scripts/tests/run.ts security",
    "test:smoke": "tsx scripts/tests/run.ts smoke",
    "ui:capture-baseline": "tsx scripts/ui/capture-baseline.ts",
    "test:all": "tsx scripts/tests/run.ts all",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@better-auth/passkey": "~1.4.9",
    "@neondatabase/auth": "latest",
    "@neondatabase/serverless": "^1.1.0",
    "@openrouter/sdk": "^0.2.11",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.49.0",
    "better-auth": "~1.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lru-cache": "^11.3.5",
    "lucide-react": "^0.542.0",
    "nanoid": "^5.1.9",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "p-retry": "^7.1.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@vitest/coverage-v8": "^4.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "16.4.0",
    "oxlint": "1.62.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^10.2.3",
      "tar": "^7.5.8",
      "rollup": ">=4.59.0",
      "serialize-javascript": "^7.0.3",
      "better-auth": "~1.4.9"
    }
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,cjs,mjs,cts,mts}": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "prettier --write --ignore-unknown"
    ],
    "**/*.{json,jsonc,css,md,mdx,yml,yaml}": "prettier --write --ignore-unknown"
  }
}
