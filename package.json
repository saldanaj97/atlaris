{
  "name": "atlaris",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "next build --turbopack",
    "dev": "next dev --turbopack",
    "dev:workflow": "next dev --webpack",
    "dev:full": "pnpm db:dev:start && pnpm dev",
    "start": "next start",
    "check:full": "concurrently --kill-others-on-fail --names lint,type --prefix-colors blue,magenta \"pnpm check:lint\" \"pnpm check:type\"",
    "check:lint": "oxlint src tests scripts supabase --max-warnings=0",
    "check:lint:ci": "oxlint src tests scripts supabase --format=github --max-warnings=0",
    "check:type": "tsgo --noEmit --checkers 4",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:dev:start": "supabase start",
    "db:dev:stop": "supabase stop",
    "db:dev:seed": "tsx scripts/seed-local-supabase.ts",
    "db:dev:reset": "supabase db reset",
    "test": "tsx scripts/tests/run-phases.ts test:unit:changed test:integration:changed",
    "test:unit": "SKIP_DB_TEST_SETUP=true NODE_ENV=test pnpm vitest run --config vitest.config.ts --project unit tests/unit",
    "test:unit:changed": "SKIP_DB_TEST_SETUP=true NODE_ENV=test pnpm vitest run --config vitest.config.ts --project unit --changed tests/unit",
    "test:integration": "NODE_ENV=test pnpm vitest run --config vitest.config.ts --project integration tests/integration",
    "test:integration:changed": "NODE_ENV=test pnpm vitest run --config vitest.config.ts --project integration --changed tests/integration && NODE_ENV=test pnpm vitest run --config vitest.workflow.config.ts --changed --passWithNoTests tests/workflow",
    "test:workflow": "NODE_ENV=test pnpm vitest run --config vitest.workflow.config.ts tests/workflow",
    "test:security": "NODE_ENV=test pnpm vitest run --config vitest.config.ts --project security tests/security",
    "test:smoke": "pnpm exec tsx scripts/tests/smoke/run.ts",
    "ui:capture-baseline": "tsx scripts/ui/capture-baseline.ts",
    "test:e2e": "NODE_ENV=test pnpm vitest run --config vitest.config.ts --project e2e tests/e2e",
    "test:all": "tsx scripts/tests/run-phases.ts check:full test:unit test:integration test:workflow test:security",
    "test:all:e2e": "tsx scripts/tests/run-phases.ts check:full test:unit test:integration test:workflow test:security test:e2e",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@clerk/nextjs": "^7.3.0",
    "@flags-sdk/vercel": "^1.3.0",
    "@openrouter/sdk": "^0.2.11",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.49.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "flags": "^4.0.6",
    "lru-cache": "^11.3.5",
    "lucide-react": "^0.542.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "p-retry": "^7.1.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "workflow": "^4.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.25",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@vitest/coverage-v8": "^4.1.4",
    "@workflow/builders": "^4.0.6",
    "@workflow/rollup": "^4.0.5",
    "@workflow/vitest": "^4.0.6",
    "@workflow/world-local": "^4.0.6",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "16.4.0",
    "nanoid": "^5.1.9",
    "oxfmt": "^0.52.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.23.0",
    "supabase": "^2.98.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "core-js",
      "cpu-features",
      "esbuild",
      "protobufjs",
      "sharp",
      "ssh2",
      "supabase"
    ],
    "overrides": {
      "@workflow/builders>esbuild": "0.28.1",
      "@workflow/cli>esbuild": "0.28.1",
      "@esbuild-kit/core-utils>esbuild": "^0.25.0",
      "@esbuild-kit/esm-loader>esbuild": "^0.25.0",
      "js-cookie": "^3.0.7",
      "minimatch": "^10.2.3",
      "tar": "^7.5.16",
      "rollup": "^4.59.0",
      "serialize-javascript": "^7.0.3",
      "fast-uri": "^3.1.2",
      "kysely": "^0.28.17",
      "undici": "^7.28.0",
      "devalue": "^5.8.1",
      "shell-quote": "^1.8.4",
      "protobufjs": "^7.6.3",
      "@protobufjs/utf8": "^1.1.1",
      "@grpc/grpc-js": "^1.14.4",
      "ws": "^8.21.0",
      "piscina": "^4.9.3",
      "postcss": "^8.5.10",
      "uuid": "^11.1.1",
      "brace-expansion": "^5.0.6",
      "@babel/core": "^7.29.6",
      "@opentelemetry/core": "^2.8.0"
    }
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,cjs,mjs,cts,mts}": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  }
}
