{
  "name": "atlaris",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build --turbopack",
    "dev": "next dev --turbopack",
    "dev:full": "pnpm db:dev:start && pnpm dev",
    "start": "next start",
    "check:full": "concurrently --kill-others-on-fail --names lint,type --prefix-colors blue,magenta \"pnpm check:lint\" \"pnpm check:type\"",
    "check:format": "biome format --write",
    "check:lint": "biome check --max-diagnostics=1000",
    "check:lint:changed": "./scripts/biome-changed.sh check",
    "check:lint:fix": "biome check --write --max-diagnostics=1000",
    "check:knip": "knip --no-progress",
    "check:type": "tsgo --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:dev:start": "brew services start postgresql@17 && \"$(brew --prefix postgresql@17)/bin/pg_isready\" -h localhost -p 54331 -d postgres",
    "db:dev:stop": "brew services stop postgresql@17",
    "db:dev:bootstrap": "tsx scripts/bootstrap-local-db.ts",
    "db:dev:reset": "pnpm db:dev:start && PGPASSWORD=postgres \"$(brew --prefix postgresql@17)/bin/dropdb\" --if-exists -h localhost -p 54331 -U postgres atlaris_dev && PGPASSWORD=postgres \"$(brew --prefix postgresql@17)/bin/createdb\" -h localhost -p 54331 -U postgres -O postgres atlaris_dev",
    "test": "pnpm test:changed",
    "test:changed": "tsx scripts/tests/run.ts changed",
    "test:unit": "tsx scripts/tests/run.ts unit",
    "test:unit:changed": "tsx scripts/tests/run.ts unit --changed",
    "test:integration:changed": "tsx scripts/tests/run.ts integration --changed",
    "test:integration": "tsx scripts/tests/run.ts integration",
    "test:security": "tsx scripts/tests/run.ts security",
    "test:smoke": "tsx scripts/tests/run.ts smoke",
    "test:all": "tsx scripts/tests/run.ts all",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "@neondatabase/auth": "latest",
    "@neondatabase/serverless": "^1.0.2",
    "@openrouter/sdk": "^0.2.11",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.32.1",
    "better-auth": "^1.4.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "lru-cache": "^11.2.2",
    "lucide-react": "^0.542.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "p-retry": "^7.1.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.1.0",
    "postgres": "^3.4.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "stripe": "^20.2.0",
    "tailwind-merge": "^3.3.1",
    "ws": "^8.18.3",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testcontainers/postgresql": "^11.12.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "async-mutex": "^0.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.4",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "knip": "^6.4.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.20.5",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^10.2.3",
      "tar": "^7.5.8",
      "rollup": ">=4.59.0",
      "serialize-javascript": "^7.0.3"
    }
  }
}
